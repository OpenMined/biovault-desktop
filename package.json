{
	"name": "bv-desktop",
	"private": true,
	"version": "0.1.39",
	"type": "module",
	"scripts": {
		"tauri": "dotenv -- npm exec -- tauri",
		"dev": "bash -lc 'set -euo pipefail; ./scripts/ensure-bundled-deps.sh; npm run tauri -- dev'",
		"dev:frontend": "vite",
		"build": "bash -lc 'set -euo pipefail; ./scripts/fetch-bundled-deps.sh; bash ./scripts/materialize-templates.sh; npm run tauri -- build'",
		"build:frontend": "vite build",
		"build:go": "bash -lc 'set -euo pipefail; ./build-go.sh'",
		"test:ui": "playwright test"
	},
	"devDependencies": {
		"@playwright/test": "^1.48.2",
		"@tauri-apps/cli": "^2.9.6",
		"autoprefixer": "^10.4.23",
		"dotenv-cli": "^10.0.0",
		"postcss": "^8.5.6",
		"tailwindcss": "^4.1.18",
		"vite": "^7.3.1",
		"ws": "^8.17.0"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.1.18",
		"@tauri-apps/api": "^2.9.1",
		"@tauri-apps/plugin-dialog": "^2.4.0",
		"@tauri-apps/plugin-notification": "^2.1.0",
		"@tauri-apps/plugin-process": "^2.3.0",
		"@tauri-apps/plugin-updater": "^2.9.0",
		"basecoat-css": "^0.3.10"
	}
}
