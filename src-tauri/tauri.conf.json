{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "BioVault",
	"version": "0.1.39",
	"identifier": "org.openmined.biovault-desktop",
	"build": {
		"beforeDevCommand": "npm run dev:frontend",
		"beforeBuildCommand": "npm run build:frontend",
		"frontendDist": "../dist",
		"devUrl": "http://localhost:5173"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "BioVault",
				"width": 1100,
				"height": 700,
				"minWidth": 1100,
				"minHeight": 700,
				"devtools": true,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true
			}
		]
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"macOS": {
			"entitlements": "./Entitlements.plist",
			"minimumSystemVersion": "10.13"
		},
		"targets": [
			"app",
			"appimage",
			"dmg",
			"nsis"
		],
		"resources": [
			"resources/syqure",
			"resources/templates",
			"resources/bundled/README.txt",
			"resources/bundled/java",
			"resources/bundled/nextflow",
			"resources/bundled/uv"
		]
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJENkYyRTIzRkIwM0MyMkIKUldRcndnUDdJeTV2TGZTNk9seHlxd2h2ZUJvYjVobjhxdEQ1MkMreEtpN05HdU85TGpHUEFRaEoK",
			"endpoints": [
				"https://github.com/OpenMined/biovault-desktop/releases/download/updater-manifests/release-{{target}}-{{arch}}.json",
				"https://github.com/OpenMined/biovault-desktop/releases/latest/download/release.json"
			]
		},
		"deep-link": {
			"desktop": {
				"schemes": [
					"biovault"
				]
			}
		}
	}
}